{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": false,
    "skipLibCheck": false,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vite/client", "vitest/globals"]
  },
  "include": [
    "tailwind.config.ts",
    "vite.config.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "server/**/*.ts",
    "server/**/*.d.ts",
    "shared/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.d.ts"
  ]
}
